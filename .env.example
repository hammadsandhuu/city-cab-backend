# LOCAL DEVELOPMENT — City Airport Taxis Backend

# Server
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
TRUST_PROXY_HOPS=1

# Frontends (CORS + email links)
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

# Database (MongoDB Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/city-airport-taxis

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@example.com
DEFAULT_ADMIN_EMAIL=admin@example.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limiting (global /api/* — login/register use stricter per-route limits)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Authentication (JWT + sessions)
JWT_SECRET=dev_only_jwt_secret_change_me_32chars_min
JWT_REFRESH_SECRET=dev_only_refresh_secret_change_me_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REQUIRE_EMAIL_VERIFICATION=true
MAX_SESSIONS_PER_USER=10
BCRYPT_ROUNDS=12

# Redis / Upstash (OPTIONAL — REDIS_ENABLED=false by default)
REDIS_URL=
REDIS_ENABLED=false
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_MAX_RETRIES=10

# Socket.IO (WebSockets)
SOCKET_ENABLED=true
SOCKET_PATH=/socket.io

# Health checks (required in production for /health and /health/ready)
HEALTH_CHECK_TOKEN=

# Observability (optional — set SENTRY_ENABLED=true and SENTRY_DSN to enable Sentry)
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Admin seed (run: SEED_ADMIN_PASSWORD=YourPassword pnpm seed:admin)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_FIRST_NAME=Super
SEED_ADMIN_LAST_NAME=Admin
