# =============================================================================
# City Airport Taxis Backend — .gitignore
# Commit: pnpm-lock.yaml
# Never commit: .env, .env.production, secrets, keys, logs, build output
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.pnpm-store/
.pnpm/
.pnpm-debug.log*

# Legacy lockfiles (use pnpm-lock.yaml)
package-lock.json
yarn.lock
bun.lock
bun.lockb

# -----------------------------------------------------------------------------
# Build & runtime output
# -----------------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment & secrets (never commit)
# -----------------------------------------------------------------------------
.env
.env.*

# Local overrides / staging copies with real credentials
.env.local
.env.development
.env.development.local
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local

# Keys & certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
credentials/
credentials.json
service-account*.json

# -----------------------------------------------------------------------------
# Logs & process managers
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# PM2
.pm2/
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
.vitest/
test-results/
playwright-report/
blob-report/

# MongoDB Memory Server binary cache
.mongodb-binaries/
.mongo-binaries/

# -----------------------------------------------------------------------------
# Docker (local-only; keep Dockerfile & compose in repo)
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Linting & tooling cache
# -----------------------------------------------------------------------------
.eslintcache
.prettiercache
.stylelintcache
.cache/
.parcel-cache/
.turbo/
*.tgz

# -----------------------------------------------------------------------------
# IDE & editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.sublime-project
*.sublime-workspace
.cursor/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# OS generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Temporary & local uploads
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
uploads/
public/uploads/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.orig
*.bak
*.backup
.history/
.sentryclirc
